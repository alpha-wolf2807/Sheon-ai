# ── Sheon AI — Root Environment Template ──
# Copy this file to /backend/.env and fill in values

PORT=5000
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/Sheon?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_very_long_random_secret_string_in_production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173

# ── Google Gemini AI ──
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_your_gemini_key_here

# ── SMS Provider ──
# Choose: "twilio" or "fast2sms"
SMS_PROVIDER=twilio

# ── Twilio (International / India) ──
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Fast2SMS (India only, cheaper) ──
# Get from: https://www.fast2sms.com
FAST2SMS_API_KEY=your_fast2sms_key_here

# ── Node Environment ──
NODE_ENV=development
